@model IEnumerable<NZFarmers.Models.ShoppingCartItem>

@{
    ViewData["Title"] = "My Cart";
    var total = Model.Sum(i => i.Quantity * i.FarmerProduct.Price);
    var itemCount = Model.Sum(i => i.Quantity);
}

<style>
    .cart-page { max-width: 1140px; margin: 0 auto; padding: 2rem 1rem 4rem; }
    .cart-title { font-size: 1.75rem; font-weight: 800; letter-spacing: -.02em; margin-bottom: .25rem; }
    .cart-sub { color: var(--gray-500); font-size: .95rem; margin-bottom: 2rem; }

    .cart-item {
        display: flex; gap: 1.25rem; align-items: center;
        background: var(--white); border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg); padding: 1.1rem 1.25rem;
        margin-bottom: 1rem; box-shadow: var(--shadow-sm);
        transition: box-shadow .15s;
    }
    .cart-item:hover { box-shadow: var(--shadow); }
    .cart-item-img {
        width: 92px; height: 92px; border-radius: var(--radius);
        object-fit: cover; background: var(--gray-100); flex-shrink: 0;
    }
    .cart-item-img-placeholder {
        width: 92px; height: 92px; border-radius: var(--radius);
        background: var(--green-50); color: var(--green-600);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.75rem; flex-shrink: 0;
    }
    .cart-item-info { flex: 1; min-width: 0; }
    .cart-item-name { font-weight: 700; font-size: 1.05rem; color: var(--gray-900); text-decoration: none; }
    .cart-item-name:hover { color: var(--green-700); }
    .cart-item-farm { font-size: .82rem; color: var(--gray-500); margin-top: .15rem; }
    .cart-item-farm i { color: var(--green-600); margin-right: .25rem; }
    .cart-item-unit { font-size: .82rem; color: var(--gray-500); margin-top: .35rem; }
    .cart-stock-warn { font-size: .78rem; color: #b45309; margin-top: .25rem; }

    .qty-stepper {
        display: flex; align-items: center; border: 1px solid var(--gray-200);
        border-radius: 50px; overflow: hidden; background: var(--gray-50);
    }
    .qty-stepper button {
        border: none; background: transparent; width: 34px; height: 34px;
        cursor: pointer; color: var(--gray-700); font-size: .85rem;
        transition: background .15s;
    }
    .qty-stepper button:hover { background: var(--green-100); color: var(--green-700); }
    .qty-stepper input {
        width: 44px; border: none; background: transparent; text-align: center;
        font-weight: 600; font-size: .95rem; outline: none;
        -moz-appearance: textfield;
    }
    .qty-stepper input::-webkit-outer-spin-button,
    .qty-stepper input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

    .cart-item-subtotal { font-weight: 800; font-size: 1.1rem; min-width: 90px; text-align: right; }
    .btn-remove {
        border: none; background: transparent; color: var(--gray-500);
        width: 36px; height: 36px; border-radius: 50%; cursor: pointer;
        transition: background .15s, color .15s;
    }
    .btn-remove:hover { background: #fee2e2; color: #dc2626; }

    /* Summary card */
    .cart-summary {
        background: var(--white); border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm);
        position: sticky; top: 140px;
    }
    .summary-row { display: flex; justify-content: space-between; font-size: .95rem; color: var(--gray-700); margin-bottom: .65rem; }
    .summary-total { display: flex; justify-content: space-between; font-weight: 800; font-size: 1.25rem; padding-top: .75rem; border-top: 1px solid var(--gray-200); }
    .btn-checkout {
        display: flex; align-items: center; justify-content: center; gap: .5rem;
        width: 100%; background: var(--green-600); color: white; border: none;
        border-radius: 50px; padding: .85rem; font-weight: 700; font-size: 1rem;
        margin-top: 1.25rem; cursor: pointer; transition: background .15s, transform .15s;
        box-shadow: 0 2px 8px rgba(22,163,74,.35);
    }
    .btn-checkout:hover { background: var(--green-700); transform: translateY(-1px); }
    .secure-note { display: flex; align-items: center; justify-content: center; gap: .4rem; font-size: .78rem; color: var(--gray-500); margin-top: .85rem; }
    .secure-note i { color: var(--green-600); }

    /* Empty state */
    .cart-empty {
        text-align: center; padding: 5rem 1rem;
        background: var(--white); border: 1px dashed var(--gray-200); border-radius: var(--radius-lg);
    }
    .cart-empty-icon {
        width: 84px; height: 84px; border-radius: 50%; background: var(--green-50);
        color: var(--green-600); font-size: 2rem; display: inline-flex;
        align-items: center; justify-content: center; margin-bottom: 1.25rem;
    }
    .btn-browse {
        display: inline-flex; align-items: center; gap: .5rem;
        background: var(--green-600); color: white; text-decoration: none;
        border-radius: 50px; padding: .75rem 1.75rem; font-weight: 700;
        transition: background .15s;
    }
    .btn-browse:hover { background: var(--green-700); color: white; }

    @@media (max-width: 767px) {
        .cart-item { flex-wrap: wrap; }
        .cart-item-subtotal { text-align: left; }
        .cart-summary { position: static; }
    }
</style>

<div class="cart-page">
    <h1 class="cart-title"><i class="fas fa-shopping-cart me-2" style="color:var(--green-600);"></i>My Cart</h1>

    @if (!Model.Any())
    {
        <p class="cart-sub">Your cart is empty.</p>
        <div class="cart-empty">
            <div class="cart-empty-icon"><i class="fas fa-shopping-basket"></i></div>
            <h4 style="font-weight:700;">Nothing here yet</h4>
            <p style="color:var(--gray-500);max-width:380px;margin:0 auto 1.5rem;">
                Fill your basket with fresh, local produce straight from New Zealand farms.
            </p>
            <a class="btn-browse" asp-controller="FarmerProducts" asp-action="Index">
                <i class="fas fa-seedling"></i> Browse Products
            </a>
        </div>
    }
    else
    {
        <p class="cart-sub">@itemCount item@(itemCount == 1 ? "" : "s") from @Model.Select(i => i.FarmerProduct.FarmerID).Distinct().Count() farm@(Model.Select(i => i.FarmerProduct.FarmerID).Distinct().Count() == 1 ? "" : "s")</p>

        <div class="row g-4">
            <!-- Items -->
            <div class="col-lg-8">
                @foreach (var item in Model)
                {
                    <div class="cart-item">
                        @if (!string.IsNullOrEmpty(item.FarmerProduct.ImageURL))
                        {
                            <img src="@item.FarmerProduct.ImageURL" alt="@item.FarmerProduct.ProductName" class="cart-item-img" onerror="this.outerHTML='&lt;div class=&quot;cart-item-img-placeholder&quot;&gt;&lt;i class=&quot;fas fa-seedling&quot;&gt;&lt;/i&gt;&lt;/div&gt;'" />
                        }
                        else
                        {
                            <div class="cart-item-img-placeholder"><i class="fas fa-seedling"></i></div>
                        }

                        <div class="cart-item-info">
                            <a class="cart-item-name" asp-controller="FarmerProducts" asp-action="Details" asp-route-id="@item.FarmerProductID">
                                @item.FarmerProduct.ProductName
                            </a>
                            @if (item.FarmerProduct.Farmer != null)
                            {
                                <div class="cart-item-farm"><i class="fas fa-tractor"></i>@item.FarmerProduct.Farmer.FarmName</div>
                            }
                            <div class="cart-item-unit">$@item.FarmerProduct.Price.ToString("F2") each</div>
                            @if (item.Quantity >= item.FarmerProduct.Stock)
                            {
                                <div class="cart-stock-warn"><i class="fas fa-exclamation-triangle me-1"></i>Max stock reached (@item.FarmerProduct.Stock available)</div>
                            }
                        </div>

                        <!-- Quantity stepper -->
                        <form asp-action="UpdateQuantity" method="post" class="qty-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cartItemId" value="@item.ShoppingCartItemID" />
                            <div class="qty-stepper">
                                <button type="submit" name="quantity" value="@(item.Quantity - 1)" title="Decrease"><i class="fas fa-minus"></i></button>
                                <input type="number" value="@item.Quantity" readonly />
                                <button type="submit" name="quantity" value="@(item.Quantity + 1)" title="Increase" @(item.Quantity >= item.FarmerProduct.Stock ? "disabled" : "")><i class="fas fa-plus"></i></button>
                            </div>
                        </form>

                        <div class="cart-item-subtotal">$@((item.Quantity * item.FarmerProduct.Price).ToString("F2"))</div>

                        <form asp-action="RemoveItem" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cartItemId" value="@item.ShoppingCartItemID" />
                            <button type="submit" class="btn-remove" title="Remove"><i class="fas fa-trash-alt"></i></button>
                        </form>
                    </div>
                }
            </div>

            <!-- Summary -->
            <div class="col-lg-4">
                <div class="cart-summary">
                    <h5 style="font-weight:800;margin-bottom:1.25rem;">Order Summary</h5>
                    <div class="summary-row"><span>Subtotal (@itemCount item@(itemCount == 1 ? "" : "s"))</span><span>$@total.ToString("F2")</span></div>
                    <div class="summary-row"><span>Delivery</span><span style="color:var(--green-600);font-weight:600;">Arranged with farmer</span></div>
                    <div class="summary-total"><span>Total</span><span>$@total.ToString("F2") NZD</span></div>

                    <form asp-action="Checkout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-checkout">
                            <i class="fas fa-lock"></i> Secure Checkout
                        </button>
                    </form>
                    <div class="secure-note"><i class="fab fa-stripe"></i> Payments securely processed by Stripe</div>
                </div>
            </div>
        </div>
    }
</div>
