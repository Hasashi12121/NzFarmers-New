@model PaginatedList<NZFarmers.Models.FarmerProduct>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Browse Products — NZFarmers";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentSearch   = ViewData["CurrentSearch"]   as string ?? "";
    var currentCategory = ViewData["CurrentCategory"] as string ?? "";
}

<style>
    .listings-page {
        background: #f9fafb;
        min-height: 100vh;
        padding-bottom: 4rem;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
    }
    .listings-wide { max-width: 1560px; margin: 0 auto; padding: 0 2rem; }

    /* Page header */
    .listings-header {
        background: white;
        border-bottom: 1px solid #e5e7eb;
        padding: 1.5rem 0;
        margin-bottom: 1.5rem;
    }
    .listings-header h1 { font-size: 1.8rem; font-weight: 800; letter-spacing: -.02em; margin: 0; }
    .listings-breadcrumb { font-size: .8rem; color: #9ca3af; margin-bottom: .25rem; }
    .listings-breadcrumb a { color: #15803d; text-decoration: none; }

    /* Filter row */
    .filter-row {
        display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
        background: white; border: 1px solid #e5e7eb; border-radius: 50px;
        padding: .5rem .6rem; margin-bottom: 1.25rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.04);
    }
    .filter-row form { display: flex; align-items: center; gap: .6rem; flex: 1; flex-wrap: wrap; }
    .filter-search { flex: 2; min-width: 220px; display: flex; align-items: center; gap: .5rem; padding-left: .9rem; }
    .filter-search i { color: #9ca3af; }
    .filter-search input { flex: 1; border: none; outline: none; font-size: .95rem; padding: .55rem 0; background: transparent; }
    .filter-select {
        border: 1.5px solid #e5e7eb; border-radius: 50px;
        padding: .55rem 1.1rem; font-size: .9rem; font-weight: 600; color: #374151;
        outline: none; background: #f9fafb; cursor: pointer;
    }
    .btn-filter {
        background: #16a34a; color: white; border: none; border-radius: 50px;
        padding: .6rem 1.6rem; font-weight: 700; font-size: .9rem;
        cursor: pointer; transition: background .15s;
    }
    .btn-filter:hover { background: #15803d; }
    .btn-clear {
        color: #6b7280; font-size: .85rem; font-weight: 600; text-decoration: none;
        padding: .5rem .9rem; border-radius: 50px; white-space: nowrap;
    }
    .btn-clear:hover { background: #f3f4f6; color: #374151; }

    /* Results bar */
    .results-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; flex-wrap: wrap; gap: .5rem; }
    .results-count { font-size: .9rem; color: #6b7280; }
    .results-count strong { color: #111827; }
    .btn-list-product {
        display: inline-flex; align-items: center; gap: .45rem;
        background: #f97316; color: white; text-decoration: none;
        padding: .55rem 1.3rem; border-radius: 50px; font-weight: 700; font-size: .88rem;
        box-shadow: 0 2px 8px rgba(249,115,22,.35); transition: background .15s, transform .15s;
    }
    .btn-list-product:hover { background: #ea6c0d; color: white; transform: translateY(-1px); }

    /* ── New World style product grid ── */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(225px, 1fr));
        gap: 1rem;
    }

    .p-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        position: relative;
        transition: transform .2s, box-shadow .25s, border-color .2s;
    }
    .p-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 34px rgba(0,0,0,.1);
        border-color: #bbf7d0;
    }

    .p-card-img { height: 200px; overflow: hidden; background: #fff; position: relative; border-bottom: 1px solid #f3f4f6; }
    .p-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .35s; }
    .p-card:hover .p-card-img img { transform: scale(1.05); }
    .p-card-no-img { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 3rem; color: #d1d5db; background: #f9fafb; }

    .p-badge {
        position: absolute; top: 10px; left: 10px;
        background: #16a34a; color: white;
        font-size: .66rem; font-weight: 800; letter-spacing: .05em; text-transform: uppercase;
        padding: .25rem .65rem; border-radius: 50px;
        box-shadow: 0 2px 6px rgba(0,0,0,.15);
    }
    .p-stock-flag {
        position: absolute; top: 10px; right: 10px;
        background: rgba(255,255,255,.92); backdrop-filter: blur(4px);
        color: #15803d; font-size: .66rem; font-weight: 700;
        padding: .25rem .6rem; border-radius: 50px;
    }
    .p-stock-flag.low { color: #b45309; }
    .p-stock-flag.out { color: #dc2626; }

    .p-body { padding: .9rem 1rem 1rem; flex: 1; display: flex; flex-direction: column; }
    .p-name { font-size: 1rem; font-weight: 700; color: #111827; line-height: 1.3; margin-bottom: .2rem; }
    .p-name a { color: inherit; text-decoration: none; }
    .p-name a:hover { color: #15803d; }
    .p-farm { font-size: .76rem; color: #6b7280; display: flex; align-items: center; gap: .3rem; margin-bottom: .7rem; }

    /* Big NW-style price */
    .p-price-row { display: flex; align-items: baseline; gap: .3rem; margin-top: auto; }
    .p-price-dollars { font-size: 1.7rem; font-weight: 800; color: #111827; line-height: 1; }
    .p-price-cents { font-size: .95rem; font-weight: 800; color: #111827; }
    .p-price-ea { font-size: .75rem; color: #6b7280; font-weight: 600; }

    .p-buy-row { display: flex; align-items: stretch; gap: .5rem; margin-top: .75rem; }
    .p-qty {
        display: flex; align-items: center; border: 1.5px solid #e5e7eb; border-radius: 10px; overflow: hidden; background: #f9fafb;
    }
    .p-qty button { border: none; background: transparent; width: 30px; height: 38px; cursor: pointer; color: #374151; font-size: .75rem; }
    .p-qty button:hover { background: #dcfce7; color: #15803d; }
    .p-qty input { width: 34px; border: none; background: transparent; text-align: center; font-weight: 700; font-size: .9rem; outline: none; -moz-appearance: textfield; }
    .p-qty input::-webkit-outer-spin-button, .p-qty input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .btn-add {
        flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: .4rem;
        background: #16a34a; color: white; border: none; border-radius: 10px;
        font-weight: 700; font-size: .9rem; cursor: pointer;
        transition: background .15s, transform .1s;
    }
    .btn-add:hover { background: #15803d; transform: translateY(-1px); }
    .btn-add.disabled, .btn-add:disabled { background: #e5e7eb; color: #9ca3af; cursor: not-allowed; transform: none; }
    .btn-signin-add {
        flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: .4rem;
        background: #f0fdf4; color: #15803d; border: 1.5px solid #bbf7d0; border-radius: 10px;
        font-weight: 700; font-size: .85rem; text-decoration: none; padding: .55rem;
        transition: background .15s;
    }
    .btn-signin-add:hover { background: #dcfce7; color: #166534; }

    .p-manage { position: absolute; bottom: 100%; }
    .p-edit-fab {
        position: absolute; right: 10px; bottom: 10px;
        width: 32px; height: 32px; border-radius: 50%;
        background: rgba(255,255,255,.95); color: #6b7280;
        display: flex; align-items: center; justify-content: center;
        font-size: .75rem; text-decoration: none; box-shadow: 0 2px 8px rgba(0,0,0,.18);
        transition: background .15s, color .15s;
    }
    .p-edit-fab:hover { background: #16a34a; color: white; }

    /* Empty state */
    .empty-state { text-align: center; padding: 5rem 2rem; background: white; border-radius: 16px; border: 1px solid #e5e7eb; }
    .empty-state .emoji { font-size: 4rem; margin-bottom: 1rem; }
    .empty-state h3 { font-weight: 700; color: #374151; }
    .empty-state p { color: #9ca3af; }

    /* Pagination */
    .pagination-wrap { margin-top: 2.5rem; display: flex; justify-content: center; gap: .35rem; flex-wrap: wrap; }
    .page-btn {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 40px; height: 40px; padding: 0 .8rem;
        border: 1.5px solid #e5e7eb; border-radius: 10px;
        font-size: .9rem; font-weight: 600; color: #374151;
        text-decoration: none; background: white; transition: all .15s;
    }
    .page-btn:hover { background: #f0fdf4; border-color: #16a34a; color: #15803d; }
    .page-btn.active { background: #15803d; border-color: #15803d; color: white; }
    .page-btn.disabled { opacity: .4; pointer-events: none; }

    @@media (max-width: 575px) {
        .listings-wide { padding: 0 1rem; }
        .product-grid { grid-template-columns: 1fr 1fr; gap: .7rem; }
        .p-card-img { height: 140px; }
        .p-price-dollars { font-size: 1.35rem; }
        .filter-row { border-radius: 16px; }
    }
</style>

<div class="listings-page">
    <!-- Page Header -->
    <div class="listings-header">
        <div class="listings-wide">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div>
                    <div class="listings-breadcrumb">
                        <a asp-controller="Home" asp-action="Index">Home</a> / Products
                    </div>
                    <h1>
                        @if (!string.IsNullOrEmpty(currentCategory))
                        {
                            @currentCategory
                        }
                        else
                        {
                            <text>Fresh Products</text>
                        }
                    </h1>
                </div>
                @if (User.IsInRole("Admin") || User.IsInRole("Farmer"))
                {
                    <a asp-action="Create" class="btn-list-product">
                        <i class="fas fa-plus"></i> List a Product
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="listings-wide">
        <!-- Filter row -->
        <div class="filter-row">
            <form asp-action="Index" method="get">
                <div class="filter-search">
                    <i class="fas fa-search"></i>
                    <input type="text" name="searchString" value="@currentSearch" placeholder="Search products, farms, locations…" />
                </div>
                <select name="categoryFilter" class="filter-select" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    @foreach (ProductCategory pc in Enum.GetValues(typeof(ProductCategory)))
                    {
                        if (currentCategory == pc.ToString())
                        {
                            <option value="@pc" selected>@pc</option>
                        }
                        else
                        {
                            <option value="@pc">@pc</option>
                        }
                    }
                </select>
                <button type="submit" class="btn-filter"><i class="fas fa-search me-1"></i> Search</button>
                @if (!string.IsNullOrEmpty(currentSearch) || !string.IsNullOrEmpty(currentCategory))
                {
                    <a asp-action="Index" class="btn-clear"><i class="fas fa-times me-1"></i>Clear</a>
                }
            </form>
        </div>

        <!-- Results bar -->
        <div class="results-bar">
            <div class="results-count">
                <strong>@Model.TotalCount</strong> product@(Model.TotalCount == 1 ? "" : "s") found
                @if (!string.IsNullOrEmpty(currentCategory)) { <text> in <strong>@currentCategory</strong></text> }
                @if (!string.IsNullOrEmpty(currentSearch)) { <text> for "<strong>@currentSearch</strong>"</text> }
            </div>
        </div>

        <!-- Products -->
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="emoji">🌱</div>
                <h3>No products found</h3>
                <p>Try adjusting your filters or search terms.</p>
                <a asp-action="Index"
                   style="display:inline-flex;align-items:center;gap:.4rem;background:#15803d;color:white;text-decoration:none;padding:.65rem 1.5rem;border-radius:50px;font-weight:700;font-size:.875rem;margin-top:.75rem;">
                    <i class="fas fa-th"></i> View All Products
                </a>
            </div>
        }
        else
        {
            <div class="product-grid">
                @foreach (var item in Model)
                {
                    var dollars = (int)Math.Floor(item.Price);
                    var cents = (int)Math.Round((item.Price - dollars) * 100);

                    <div class="p-card">
                        <div class="p-card-img">
                            @if (!string.IsNullOrEmpty(item.ImageURL))
                            {
                                <img src="@item.ImageURL" alt="@item.ProductName"
                                     onerror="this.parentElement.innerHTML='<div class=\'p-card-no-img\'>🌿</div>'" />
                            }
                            else
                            {
                                <div class="p-card-no-img">🌿</div>
                            }
                            <span class="p-badge">@item.Category</span>
                            <span class="p-stock-flag @(item.Stock == 0 ? "out" : item.Stock < 5 ? "low" : "")">
                                @(item.Stock > 0 ? $"{item.Stock} left" : "Out of stock")
                            </span>
                            @if (User.IsInRole("Admin") || User.IsInRole("Farmer"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.FarmerProductID" class="p-edit-fab" title="Edit">
                                    <i class="fas fa-pen"></i>
                                </a>
                            }
                        </div>
                        <div class="p-body">
                            <div class="p-name">
                                <a asp-action="Details" asp-route-id="@item.FarmerProductID">@item.ProductName</a>
                            </div>
                            <div class="p-farm">
                                <i class="fas fa-tractor" style="color:#16a34a;font-size:.65rem;"></i>
                                @item.Farmer?.FarmName
                                <span style="margin-left:auto;color:#9ca3af;">
                                    <i class="fas fa-map-marker-alt" style="color:#f97316;"></i>
                                    @item.Farmer?.City
                                </span>
                            </div>

                            <div class="p-price-row">
                                <span class="p-price-dollars">$@dollars</span><span class="p-price-cents">.@cents.ToString("D2")</span>
                                <span class="p-price-ea">ea</span>
                            </div>

                            <div class="p-buy-row">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    if (item.Stock > 0)
                                    {
                                        <form asp-controller="ShoppingCartItems" asp-action="AddToCart" method="post" style="display:flex;gap:.5rem;flex:1;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="farmerProductId" value="@item.FarmerProductID" />
                                            <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                                            <div class="p-qty">
                                                <button type="button" onclick="nwStep(this, -1)"><i class="fas fa-minus"></i></button>
                                                <input type="number" name="quantity" value="1" min="1" max="@item.Stock" />
                                                <button type="button" onclick="nwStep(this, 1)"><i class="fas fa-plus"></i></button>
                                            </div>
                                            <button type="submit" class="btn-add"><i class="fas fa-cart-plus"></i> Add</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn-add disabled" disabled style="padding:.55rem;"><i class="fas fa-ban"></i> Out of stock</button>
                                    }
                                }
                                else
                                {
                                    <a class="btn-signin-add" href="/Identity/Account/Login">
                                        <i class="fas fa-sign-in-alt"></i> Sign in to buy
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="pagination-wrap">
                    <a asp-action="Index"
                       asp-route-pageNumber="@(Model.PageIndex - 1)"
                       asp-route-searchString="@currentSearch"
                       asp-route-categoryFilter="@currentCategory"
                       class="page-btn @(!Model.HasPreviousPage ? "disabled" : "")">
                        <i class="fas fa-chevron-left"></i>
                    </a>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a asp-action="Index"
                           asp-route-pageNumber="@i"
                           asp-route-searchString="@currentSearch"
                           asp-route-categoryFilter="@currentCategory"
                           class="page-btn @(i == Model.PageIndex ? "active" : "")">
                            @i
                        </a>
                    }

                    <a asp-action="Index"
                       asp-route-pageNumber="@(Model.PageIndex + 1)"
                       asp-route-searchString="@currentSearch"
                       asp-route-categoryFilter="@currentCategory"
                       class="page-btn @(!Model.HasNextPage ? "disabled" : "")">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        function nwStep(btn, delta) {
            const input = btn.closest('.p-qty').querySelector('input');
            const max = parseInt(input.max) || 999;
            let val = (parseInt(input.value) || 1) + delta;
            input.value = Math.min(max, Math.max(1, val));
        }
    </script>
}
