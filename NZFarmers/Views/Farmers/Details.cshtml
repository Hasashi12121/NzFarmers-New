@model NZFarmers.Models.Farmers
@{
    ViewData["Title"] = Model.FarmName;
}

<div class="fd-page">

    <!-- Breadcrumb -->
    <div class="fd-breadcrumb">
        <div class="fd-container">
            <nav class="breadcrumb-nav" aria-label="breadcrumb">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <span class="bc-sep"><i class="fas fa-chevron-right"></i></span>
                <a asp-controller="Farmers" asp-action="Index">Farmers</a>
                <span class="bc-sep"><i class="fas fa-chevron-right"></i></span>
                <span class="bc-current">@Model.FarmName</span>
            </nav>
        </div>
    </div>

    <!-- Hero banner -->
    <div class="fd-hero">
        @if (!string.IsNullOrEmpty(Model.ProfileImage))
        {
            <img src="@Model.ProfileImage" alt="@Model.FarmName" class="fd-hero-img" />
        }
        else
        {
            <div class="fd-hero-placeholder">
                <span class="hero-placeholder-icon">🌿</span>
            </div>
        }
    </div>

    <!-- Main layout -->
    <div class="fd-container fd-layout">

        <!-- LEFT: main content -->
        <main class="fd-main">

            <div class="fd-title-block">
                <div class="fd-title-top">
                    <span class="fd-badge">
                        <i class="fas fa-check-circle"></i> Verified Farm
                    </span>
                    @if (User.IsInRole("Admin") || User.IsInRole("Farmer"))
                    {
                        <div class="fd-admin-actions">
                            <a asp-action="Edit" asp-route-id="@Model.FarmerID" class="fd-action-link">
                                <i class="fas fa-pencil-alt"></i> Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.FarmerID" class="fd-action-link fd-action-danger">
                                <i class="fas fa-trash"></i> Delete
                            </a>
                        </div>
                    }
                </div>
                <h1 class="fd-farm-name">@Model.FarmName</h1>
                <p class="fd-location">
                    <i class="fas fa-map-marker-alt"></i>
                    @Model.City, @Model.Region@(!string.IsNullOrEmpty(Model.ZipCode) ? $" {Model.ZipCode}" : "")
                </p>
            </div>

            <!-- Description -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="fd-section">
                    <h2 class="fd-section-title">About this farm</h2>
                    <p class="fd-description">@Model.Description</p>
                </div>
            }

            <!-- Details table -->
            <div class="fd-section">
                <h2 class="fd-section-title">Farm details</h2>
                <div class="fd-details-table">
                    <div class="fd-detail-row">
                        <div class="fd-detail-key"><i class="fas fa-tractor"></i> Farm Name</div>
                        <div class="fd-detail-val">@Model.FarmName</div>
                    </div>
                    <div class="fd-detail-row">
                        <div class="fd-detail-key"><i class="fas fa-city"></i> City</div>
                        <div class="fd-detail-val">@Model.City</div>
                    </div>
                    <div class="fd-detail-row">
                        <div class="fd-detail-key"><i class="fas fa-map"></i> Region</div>
                        <div class="fd-detail-val">@Model.Region</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Address))
                    {
                        <div class="fd-detail-row">
                            <div class="fd-detail-key"><i class="fas fa-home"></i> Address</div>
                            <div class="fd-detail-val">@Model.Address</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ZipCode))
                    {
                        <div class="fd-detail-row">
                            <div class="fd-detail-key"><i class="fas fa-envelope"></i> Postcode</div>
                            <div class="fd-detail-val">@Model.ZipCode</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                    {
                        <div class="fd-detail-row">
                            <div class="fd-detail-key"><i class="fas fa-phone"></i> Phone</div>
                            <div class="fd-detail-val">@Model.PhoneNumber</div>
                        </div>
                    }
                </div>
            </div>

            @{
                var reviews = ViewBag.Reviews as List<NZFarmers.Models.Rating> ?? new List<NZFarmers.Models.Rating>();
                double avgRating = ViewBag.AvgRating is double avg ? avg : 0.0;
                bool canReview = ViewBag.CanReview is bool cr && cr;
                bool isOwner = ViewBag.IsOwner is bool io && io;
                var myReview = ViewBag.MyReview as NZFarmers.Models.Rating;
            }

            <!-- Reviews -->
            <div class="fd-section" id="reviews">
                <div class="rv-head">
                    <h2 class="rv-title"><i class="fas fa-star" style="color:#f59e0b;"></i> Reviews</h2>
                    @if (reviews.Any())
                    {
                        <div class="rv-avg">
                            <span class="rv-avg-num">@avgRating.ToString("F1")</span>
                            <span class="rv-avg-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fas fa-star @(i <= Math.Round(avgRating) ? "" : "rv-star-muted")"></i>
                                }
                            </span>
                            <span class="rv-avg-count">(@reviews.Count review@(reviews.Count == 1 ? "" : "s"))</span>
                        </div>
                    }
                </div>

                @if (canReview)
                {
                    <form class="rv-form" asp-controller="Ratings" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="FarmerID" value="@Model.FarmerID" />
                        <div class="rv-form-title">@(myReview != null ? "Update your review" : "Leave a review")</div>
                        <div class="rv-star-input">
                            @for (int s = 5; s >= 1; s--)
                            {
                                <input type="radio" id="star@(s)" name="RatingValue" value="@s" @(myReview != null && myReview.RatingValue == s ? "checked" : (myReview == null && s == 5 ? "checked" : "")) />
                                <label for="star@(s)" title="@s star@(s == 1 ? "" : "s")"><i class="fas fa-star"></i></label>
                            }
                        </div>
                        <textarea name="Comment" class="rv-textarea" rows="3" maxlength="500"
                                  placeholder="How was your experience with @Model.FarmName?">@myReview?.Comment</textarea>
                        <button type="submit" class="rv-submit">
                            <i class="fas fa-paper-plane"></i> @(myReview != null ? "Update Review" : "Post Review")
                        </button>
                    </form>
                }
                else if (isOwner)
                {
                    <p class="rv-note"><i class="fas fa-info-circle me-1"></i>This is your farm — reviews from your customers will appear here.</p>
                }
                else if (User.Identity?.IsAuthenticated != true)
                {
                    <p class="rv-note">
                        <a href="/Identity/Account/Login">Sign in</a> to leave a review.
                    </p>
                }

                @if (!reviews.Any())
                {
                    <div class="rv-empty">
                        <i class="far fa-comment-dots"></i>
                        <p>No reviews yet — be the first to share your experience.</p>
                    </div>
                }
                else
                {
                    <div class="rv-list">
                        @foreach (var review in reviews)
                        {
                            <div class="rv-item">
                                <div class="rv-item-avatar">@((review.User?.Email ?? "?").Substring(0, 1).ToUpper())</div>
                                <div class="rv-item-body">
                                    <div class="rv-item-top">
                                        <span class="rv-item-name">@(review.User?.Email ?? "Customer")</span>
                                        <span class="rv-item-stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fas fa-star @(i <= review.RatingValue ? "" : "rv-star-muted")"></i>
                                            }
                                        </span>
                                        <span class="rv-item-date">@review.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(review.Comment))
                                    {
                                        <p class="rv-item-comment">@review.Comment</p>
                                    }
                                    @if (User.IsInRole("Admin") || (myReview != null && review.RatingID == myReview.RatingID))
                                    {
                                        <div class="rv-item-actions">
                                            <a asp-controller="Ratings" asp-action="Delete" asp-route-id="@review.RatingID"><i class="fas fa-trash-alt me-1"></i>Delete</a>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <style>
                .rv-head { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .75rem; margin-bottom: 1.25rem; }
                .rv-title { font-size: 1.15rem; font-weight: 800; margin: 0; }
                .rv-avg { display: flex; align-items: center; gap: .5rem; }
                .rv-avg-num { font-weight: 800; font-size: 1.15rem; }
                .rv-avg-stars { color: #f59e0b; font-size: .9rem; }
                .rv-star-muted { color: #e5e7eb !important; }
                .rv-avg-count { color: #6b7280; font-size: .85rem; }

                .rv-form { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 10px; padding: 1.25rem; margin-bottom: 1.5rem; }
                .rv-form-title { font-weight: 700; font-size: .95rem; margin-bottom: .6rem; }
                .rv-star-input { display: inline-flex; flex-direction: row-reverse; gap: .2rem; margin-bottom: .75rem; }
                .rv-star-input input { display: none; }
                .rv-star-input label { cursor: pointer; font-size: 1.45rem; color: #e5e7eb; transition: color .1s, transform .1s; }
                .rv-star-input label:hover { transform: scale(1.15); }
                .rv-star-input input:checked ~ label,
                .rv-star-input label:hover,
                .rv-star-input label:hover ~ label { color: #f59e0b; }
                .rv-textarea { width: 100%; border: 1.5px solid #d1d5db; border-radius: 8px; padding: .7rem 1rem; font-size: .92rem; font-family: inherit; resize: vertical; outline: none; transition: border-color .15s, box-shadow .15s; }
                .rv-textarea:focus { border-color: #16a34a; box-shadow: 0 0 0 3px rgba(22,163,74,.12); }
                .rv-submit { margin-top: .75rem; background: #16a34a; color: #fff; border: none; border-radius: 50px; padding: .6rem 1.5rem; font-weight: 700; font-size: .9rem; cursor: pointer; display: inline-flex; align-items: center; gap: .5rem; transition: background .15s; }
                .rv-submit:hover { background: #15803d; }
                .rv-note { color: #6b7280; font-size: .9rem; background: #f9fafb; border-radius: 8px; padding: .85rem 1rem; }
                .rv-note a { color: #16a34a; font-weight: 700; }

                .rv-empty { text-align: center; color: #9ca3af; padding: 2rem 1rem; }
                .rv-empty i { font-size: 2rem; margin-bottom: .5rem; display: block; }

                .rv-list { display: flex; flex-direction: column; gap: 1.1rem; }
                .rv-item { display: flex; gap: .9rem; }
                .rv-item-avatar { width: 42px; height: 42px; border-radius: 50%; background: #dcfce7; color: #15803d; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
                .rv-item-body { flex: 1; border-bottom: 1px solid #f3f4f6; padding-bottom: 1rem; }
                .rv-item:last-child .rv-item-body { border-bottom: none; padding-bottom: 0; }
                .rv-item-top { display: flex; align-items: center; gap: .6rem; flex-wrap: wrap; }
                .rv-item-name { font-weight: 700; font-size: .9rem; }
                .rv-item-stars { color: #f59e0b; font-size: .78rem; }
                .rv-item-date { color: #9ca3af; font-size: .78rem; margin-left: auto; }
                .rv-item-comment { color: #374151; font-size: .9rem; line-height: 1.6; margin: .4rem 0 0; }
                .rv-item-actions { margin-top: .4rem; }
                .rv-item-actions a { color: #dc2626; font-size: .78rem; font-weight: 600; text-decoration: none; }
                .rv-item-actions a:hover { color: #991b1b; }
            </style>

        </main>

        <!-- RIGHT: sidebar -->
        <aside class="fd-sidebar">

            <!-- Contact card -->
            <div class="fd-card">
                <div class="fd-card-header">
                    <div class="fd-farmer-avatar">
                        @Model.FarmName.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <div class="fd-card-name">@Model.FarmName</div>
                        <div class="fd-card-location">
                            <i class="fas fa-map-marker-alt"></i> @Model.City, @Model.Region
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                {
                    <a href="tel:@Model.PhoneNumber" class="fd-contact-btn fd-contact-primary">
                        <i class="fas fa-phone"></i> @Model.PhoneNumber
                    </a>
                }

                <a asp-controller="FarmerProducts" asp-action="Index"
                   asp-route-searchString="@Model.FarmName" class="fd-contact-btn fd-contact-secondary">
                    <i class="fas fa-seedling"></i> View Products
                </a>

                <div class="fd-card-divider"></div>

                <div class="fd-card-meta">
                    <div class="fd-meta-row">
                        <i class="fas fa-shield-alt"></i>
                        <span>Verified NZ Farmer</span>
                    </div>
                    <div class="fd-meta-row">
                        <i class="fas fa-map-marker-alt"></i>
                        <span>@Model.Region, New Zealand</span>
                    </div>
                </div>
            </div>

            <!-- Back to list -->
            <a asp-action="Index" class="fd-back-link">
                <i class="fas fa-arrow-left"></i> Back to all farmers
            </a>

        </aside>

    </div>
</div>

<style>
    .fd-page {
        background: #f6f5f4;
        min-height: 100vh;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        padding-bottom: 4rem;
    }

    .fd-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    /* Breadcrumb */
    .fd-breadcrumb {
        background: #fff;
        border-bottom: 1px solid #e5e7eb;
        padding: .75rem 0;
    }

    .breadcrumb-nav {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .82rem;
        flex-wrap: wrap;
    }

    .breadcrumb-nav a {
        color: #2563eb;
        text-decoration: none;
    }

    .breadcrumb-nav a:hover { text-decoration: underline; }

    .bc-sep { color: #9ca3af; font-size: .7rem; }
    .bc-current { color: #6b7280; }

    /* Hero */
    .fd-hero {
        background: #1a2e1a;
        height: 380px;
        overflow: hidden;
    }

    .fd-hero-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .fd-hero-placeholder {
        height: 100%;
        background: linear-gradient(135deg, #14532d 0%, #16a34a 60%, #22c55e 100%);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-placeholder-icon {
        font-size: 7rem;
        opacity: .3;
    }

    /* Layout */
    .fd-layout {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 2rem;
        padding-top: 2rem;
        align-items: start;
    }

    /* Title block */
    .fd-title-block {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1.75rem;
        margin-bottom: 1.25rem;
    }

    .fd-title-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .fd-badge {
        background: #dcfce7;
        color: #15803d;
        font-size: .75rem;
        font-weight: 600;
        padding: .3rem .75rem;
        border-radius: 20px;
        display: flex;
        align-items: center;
        gap: .35rem;
    }

    .fd-admin-actions {
        display: flex;
        gap: .6rem;
    }

    .fd-action-link {
        font-size: .8rem;
        font-weight: 600;
        color: #6b7280;
        text-decoration: none;
        padding: .3rem .75rem;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        transition: background .15s, color .15s;
        display: flex;
        align-items: center;
        gap: .35rem;
    }

    .fd-action-link:hover { background: #f3f4f6; color: #374151; text-decoration: none; }
    .fd-action-danger { color: #dc2626; border-color: #fecaca; }
    .fd-action-danger:hover { background: #fef2f2; color: #b91c1c; }

    .fd-farm-name {
        font-size: 2rem;
        font-weight: 800;
        color: #111827;
        margin: 0 0 .5rem;
        letter-spacing: -.02em;
    }

    .fd-location {
        color: #6b7280;
        font-size: .95rem;
        margin: 0;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .fd-location i { color: #16a34a; }

    /* Sections */
    .fd-section {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1.75rem;
        margin-bottom: 1.25rem;
    }

    .fd-section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #111827;
        margin: 0 0 1.25rem;
        padding-bottom: .75rem;
        border-bottom: 1px solid #f3f4f6;
    }

    .fd-description {
        color: #374151;
        font-size: .95rem;
        line-height: 1.7;
        margin: 0;
    }

    /* Details table */
    .fd-details-table {
        display: flex;
        flex-direction: column;
    }

    .fd-detail-row {
        display: grid;
        grid-template-columns: 160px 1fr;
        padding: .85rem 0;
        border-bottom: 1px solid #f3f4f6;
        gap: 1rem;
    }

    .fd-detail-row:last-child { border-bottom: none; }

    .fd-detail-key {
        font-size: .85rem;
        font-weight: 600;
        color: #6b7280;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .fd-detail-key i { width: 14px; color: #16a34a; text-align: center; }

    .fd-detail-val {
        font-size: .9rem;
        color: #111827;
        font-weight: 500;
    }

    /* Sidebar */
    .fd-sidebar {
        position: sticky;
        top: 1.5rem;
    }

    .fd-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
    }

    .fd-card-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid #f3f4f6;
    }

    .fd-farmer-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: linear-gradient(135deg, #16a34a, #22c55e);
        color: white;
        font-size: 1.4rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .fd-card-name {
        font-size: 1rem;
        font-weight: 700;
        color: #111827;
    }

    .fd-card-location {
        font-size: .8rem;
        color: #6b7280;
        margin-top: .15rem;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .fd-contact-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        width: 100%;
        padding: .8rem 1rem;
        border-radius: 8px;
        font-size: .9rem;
        font-weight: 700;
        text-decoration: none;
        margin-bottom: .65rem;
        transition: background .15s, transform .1s;
    }

    .fd-contact-btn:hover { transform: translateY(-1px); text-decoration: none; }

    .fd-contact-primary {
        background: #16a34a;
        color: #fff;
    }

    .fd-contact-primary:hover { background: #15803d; color: #fff; }

    .fd-contact-secondary {
        background: #f3f4f6;
        color: #374151;
    }

    .fd-contact-secondary:hover { background: #e5e7eb; color: #111827; }

    .fd-card-divider {
        border: none;
        border-top: 1px solid #f3f4f6;
        margin: 1rem 0;
    }

    .fd-card-meta {
        display: flex;
        flex-direction: column;
        gap: .6rem;
    }

    .fd-meta-row {
        display: flex;
        align-items: center;
        gap: .6rem;
        font-size: .82rem;
        color: #6b7280;
    }

    .fd-meta-row i { color: #16a34a; width: 14px; text-align: center; }

    /* Back link */
    .fd-back-link {
        display: flex;
        align-items: center;
        gap: .5rem;
        color: #6b7280;
        text-decoration: none;
        font-size: .85rem;
        font-weight: 500;
        padding: .6rem .75rem;
        border-radius: 8px;
        transition: background .15s, color .15s;
    }

    .fd-back-link:hover { background: #fff; color: #374151; text-decoration: none; }

    @@media (max-width: 900px) {
        .fd-layout {
            grid-template-columns: 1fr;
        }
        .fd-sidebar { position: static; }
        .fd-hero { height: 240px; }
        .fd-farm-name { font-size: 1.5rem; }
        .fd-detail-row { grid-template-columns: 130px 1fr; }
    }
</style>
