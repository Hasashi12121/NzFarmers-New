@model IEnumerable<Order>

@{
    ViewData["Title"] = "All Orders (Admin)";
}

<style>
    .ao-page { max-width: 1000px; margin: 0 auto; padding: 2rem 1rem 4rem; }
    .ao-title { font-size: 1.75rem; font-weight: 800; letter-spacing: -.02em; margin-bottom: 2rem; }
    .ao-table-wrap { background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
    .ao-table { width: 100%; border-collapse: collapse; font-size: .92rem; }
    .ao-table th { background: var(--gray-50); text-align: left; padding: .85rem 1.25rem; font-size: .75rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: .06em; border-bottom: 1px solid var(--gray-200); }
    .ao-table td { padding: .9rem 1.25rem; border-bottom: 1px solid var(--gray-100); vertical-align: middle; }
    .ao-table tr:last-child td { border-bottom: none; }
    .ao-table tr:hover td { background: var(--green-50); }

    .status-badge { display: inline-flex; align-items: center; font-size: .75rem; font-weight: 700; padding: .3rem .75rem; border-radius: 50px; text-transform: uppercase; letter-spacing: .04em; }
    .status-Pending    { background: #fef3c7; color: #92400e; }
    .status-Processing { background: #dbeafe; color: #1e40af; }
    .status-Shipped    { background: #e0e7ff; color: #4338ca; }
    .status-Delivered  { background: var(--green-100); color: var(--green-800); }
    .status-Cancelled  { background: #fee2e2; color: #991b1b; }

    .ao-link { color: var(--green-700); font-weight: 600; text-decoration: none; }
    .ao-link:hover { color: var(--green-800); }
</style>

<div class="ao-page">
    <h1 class="ao-title"><i class="fas fa-clipboard-list me-2" style="color:var(--green-600);"></i>All Orders</h1>

    <div class="ao-table-wrap">
        <table class="ao-table">
            <thead>
                <tr>
                    <th>Order</th>
                    <th>Customer</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td style="font-weight:700;">#@order.OrderID</td>
                        <td>@(order.User?.Email ?? "—")</td>
                        <td>@(order.OrderDetails?.Sum(od => od.Quantity) ?? 0)</td>
                        <td style="font-weight:700;">$@order.TotalPrice.ToString("F2")</td>
                        <td><span class="status-badge status-@order.Status">@order.Status</span></td>
                        <td style="color:var(--gray-500);">@order.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</td>
                        <td><a class="ao-link" asp-action="Details" asp-route-id="@order.OrderID">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
