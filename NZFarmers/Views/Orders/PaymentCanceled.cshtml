@{
    ViewData["Title"] = "Payment Canceled";
}

<style>
    .pc-page { max-width: 560px; margin: 0 auto; padding: 4rem 1rem; text-align: center; }
    .pc-icon {
        width: 96px; height: 96px; border-radius: 50%; background: #fef3c7;
        color: #d97706; font-size: 2.4rem; display: inline-flex;
        align-items: center; justify-content: center; margin-bottom: 1.5rem;
    }
    .pc-title { font-size: 2rem; font-weight: 800; letter-spacing: -.02em; margin-bottom: .5rem; }
    .pc-sub { color: var(--gray-500); margin-bottom: 2rem; }
    .pc-actions { display: flex; gap: .9rem; justify-content: center; flex-wrap: wrap; }
    .btn-primary-pill { display: inline-flex; align-items: center; gap: .5rem; background: var(--green-600); color: white; text-decoration: none; border-radius: 50px; padding: .8rem 1.9rem; font-weight: 700; transition: background .15s; }
    .btn-primary-pill:hover { background: var(--green-700); color: white; }
    .btn-outline-pill { display: inline-flex; align-items: center; gap: .5rem; background: var(--white); color: var(--gray-700); text-decoration: none; border: 1px solid var(--gray-200); border-radius: 50px; padding: .8rem 1.9rem; font-weight: 700; transition: background .15s; }
    .btn-outline-pill:hover { background: var(--gray-100); color: var(--gray-900); }
</style>

<div class="pc-page">
    <div class="pc-icon"><i class="fas fa-hand-paper"></i></div>
    <h1 class="pc-title">Payment canceled</h1>
    <p class="pc-sub">
        No worries — nothing was charged and your cart is exactly as you left it.
        Ready when you are.
    </p>
    <div class="pc-actions">
        <a class="btn-primary-pill" asp-controller="ShoppingCartItems" asp-action="Index"><i class="fas fa-shopping-cart"></i> Back to Cart</a>
        <a class="btn-outline-pill" asp-controller="FarmerProducts" asp-action="Index"><i class="fas fa-seedling"></i> Keep Browsing</a>
    </div>
</div>
