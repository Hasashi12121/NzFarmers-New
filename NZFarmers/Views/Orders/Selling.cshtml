@model IEnumerable<Order>

@{
    ViewData["Title"] = "Sales Dashboard";
    var farmerId = (int)ViewBag.FarmerID;
    string farmName = ViewBag.FarmName as string ?? "Your Farm";

    var allMyLines = Model
        .SelectMany(o => o.OrderDetails ?? Enumerable.Empty<NZFarmers.Models.OrderDetail>())
        .Where(od => od.FarmerProduct != null && od.FarmerProduct.FarmerID == farmerId)
        .ToList();

    var totalRevenue = allMyLines.Sum(l => l.Subtotal);
    var totalItemsSold = allMyLines.Sum(l => l.Quantity);
    var activeOrders = Model.Count(o => o.Status == OrderStatus.Pending || o.Status == OrderStatus.Processing || o.Status == OrderStatus.Shipped);
}

<style>
    .sell-page { max-width: 1000px; margin: 0 auto; padding: 2rem 1rem 4rem; }
    .sell-title { font-size: 1.75rem; font-weight: 800; letter-spacing: -.02em; }
    .sell-sub { color: var(--gray-500); margin-bottom: 2rem; }

    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2.25rem; }
    .stat-card {
        background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius-lg);
        padding: 1.25rem 1.4rem; box-shadow: var(--shadow-sm);
    }
    .stat-label { font-size: .78rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: .06em; }
    .stat-value { font-size: 1.65rem; font-weight: 800; margin-top: .25rem; }
    .stat-value.green { color: var(--green-700); }

    .order-card { background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius-lg); margin-bottom: 1.25rem; box-shadow: var(--shadow-sm); overflow: hidden; }
    .order-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; padding: 1rem 1.4rem; background: var(--gray-50); border-bottom: 1px solid var(--gray-200); }
    .order-id { font-weight: 800; }
    .order-date { font-size: .82rem; color: var(--gray-500); }
    .order-buyer { font-size: .85rem; color: var(--gray-700); }
    .order-buyer i { color: var(--green-600); margin-right: .3rem; }

    .status-badge { display: inline-flex; align-items: center; gap: .4rem; font-size: .78rem; font-weight: 700; padding: .35rem .85rem; border-radius: 50px; text-transform: uppercase; letter-spacing: .04em; }
    .status-Pending    { background: #fef3c7; color: #92400e; }
    .status-Processing { background: #dbeafe; color: #1e40af; }
    .status-Shipped    { background: #e0e7ff; color: #4338ca; }
    .status-Delivered  { background: var(--green-100); color: var(--green-800); }
    .status-Cancelled  { background: #fee2e2; color: #991b1b; }

    .order-items { padding: .5rem 1.4rem; }
    .order-line { display: flex; align-items: center; gap: .9rem; padding: .6rem 0; border-bottom: 1px solid var(--gray-100); font-size: .92rem; }
    .order-line:last-child { border-bottom: none; }
    .order-line-name { font-weight: 600; }
    .order-line-other { color: var(--gray-500); font-style: italic; }
    .order-line-qty { margin-left: auto; color: var(--gray-500); white-space: nowrap; }
    .order-line-price { font-weight: 700; min-width: 78px; text-align: right; }

    .order-actions { padding: .9rem 1.4rem; border-top: 1px solid var(--gray-100); display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; }
    .order-actions label { font-size: .82rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: .05em; }
    .status-select { border: 1px solid var(--gray-200); border-radius: 50px; padding: .45rem 1rem; font-size: .9rem; font-weight: 600; background: var(--gray-50); outline: none; }
    .btn-update-status { background: var(--green-600); color: white; border: none; border-radius: 50px; padding: .5rem 1.25rem; font-weight: 700; font-size: .88rem; cursor: pointer; transition: background .15s; }
    .btn-update-status:hover { background: var(--green-700); }

    .sell-empty { text-align: center; padding: 5rem 1rem; background: var(--white); border: 1px dashed var(--gray-200); border-radius: var(--radius-lg); }
    .sell-empty-icon { width: 84px; height: 84px; border-radius: 50%; background: var(--green-50); color: var(--green-600); font-size: 2rem; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; }
</style>

<div class="sell-page">
    <h1 class="sell-title"><i class="fas fa-store me-2" style="color:var(--green-600);"></i>Sales Dashboard</h1>
    <p class="sell-sub">Orders containing products from <strong>@farmName</strong></p>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-label">Total Revenue</div>
            <div class="stat-value green">$@totalRevenue.ToString("F2")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Items Sold</div>
            <div class="stat-value">@totalItemsSold</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Total Orders</div>
            <div class="stat-value">@Model.Count()</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Active Orders</div>
            <div class="stat-value">@activeOrders</div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="sell-empty">
            <div class="sell-empty-icon"><i class="fas fa-hand-holding-usd"></i></div>
            <h4 style="font-weight:700;">No sales yet</h4>
            <p style="color:var(--gray-500);max-width:420px;margin:0 auto;">
                When customers buy your products, their orders will appear here so you can
                prepare them and update delivery status.
            </p>
        </div>
    }
    else
    {
        foreach (var order in Model)
        {
            var myLines = (order.OrderDetails ?? Enumerable.Empty<NZFarmers.Models.OrderDetail>())
                .Where(od => od.FarmerProduct != null && od.FarmerProduct.FarmerID == farmerId).ToList();
            var otherCount = (order.OrderDetails?.Count ?? 0) - myLines.Count;

            <div class="order-card">
                <div class="order-head">
                    <div>
                        <div class="order-id">Order #@order.OrderID</div>
                        <div class="order-date">@order.CreatedAt.ToLocalTime().ToString("d MMM yyyy, h:mm tt")</div>
                    </div>
                    <div class="order-buyer">
                        <i class="fas fa-user"></i>
                        @(string.IsNullOrEmpty(order.User?.Email) ? "Customer" : order.User.Email)
                    </div>
                    <span class="status-badge status-@order.Status">@order.Status</span>
                </div>

                <div class="order-items">
                    @foreach (var line in myLines)
                    {
                        <div class="order-line">
                            <div class="order-line-name">@line.FarmerProduct?.ProductName</div>
                            <span class="order-line-qty">× @line.Quantity</span>
                            <span class="order-line-price">$@line.Subtotal.ToString("F2")</span>
                        </div>
                    }
                    @if (otherCount > 0)
                    {
                        <div class="order-line">
                            <div class="order-line-other">+ @otherCount item@(otherCount == 1 ? "" : "s") from other farms</div>
                        </div>
                    }
                </div>

                <div class="order-actions">
                    <label>Update status:</label>
                    <form asp-action="UpdateStatus" method="post" style="display:flex;align-items:center;gap:.6rem;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" value="@order.OrderID" />
                        <input type="hidden" name="returnUrl" value="@Url.Action("Selling")" />
                        <select name="status" class="status-select">
                            @foreach (OrderStatus s in Enum.GetValues(typeof(OrderStatus)))
                            {
                                if (s == order.Status)
                                {
                                    <option value="@s" selected>@s</option>
                                }
                                else
                                {
                                    <option value="@s">@s</option>
                                }
                            }
                        </select>
                        <button type="submit" class="btn-update-status"><i class="fas fa-check me-1"></i>Update</button>
                    </form>
                    <a asp-action="Details" asp-route-id="@order.OrderID" style="margin-left:auto;color:var(--green-700);font-weight:600;font-size:.9rem;text-decoration:none;">
                        Full details <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        }
    }
</div>
