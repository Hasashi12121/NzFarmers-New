@model NZFarmers.Models.Rating

@{
    ViewData["Title"] = "Delete Review";
}

<style>
    .rd-page { max-width: 560px; margin: 0 auto; padding: 3rem 1rem 4rem; }
    .rd-card { background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); padding: 2rem; text-align: center; }
    .rd-icon { width: 72px; height: 72px; border-radius: 50%; background: #fee2e2; color: #dc2626; font-size: 1.7rem; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; }
    .rd-title { font-size: 1.4rem; font-weight: 800; margin-bottom: .5rem; }
    .rd-sub { color: var(--gray-500); font-size: .92rem; margin-bottom: 1.5rem; }
    .rd-review { background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: var(--radius); padding: 1.1rem 1.25rem; text-align: left; margin-bottom: 1.75rem; }
    .rd-stars { color: #f59e0b; font-size: .9rem; margin-bottom: .35rem; }
    .rd-stars .muted { color: var(--gray-200); }
    .rd-comment { color: var(--gray-700); font-size: .92rem; margin: 0; }
    .rd-meta { color: var(--gray-500); font-size: .78rem; margin-top: .5rem; }
    .rd-actions { display: flex; gap: .9rem; justify-content: center; }
    .rd-delete { background: #dc2626; color: white; border: none; border-radius: 50px; padding: .7rem 1.75rem; font-weight: 700; cursor: pointer; }
    .rd-delete:hover { background: #b91c1c; }
    .rd-cancel { display: inline-flex; align-items: center; background: var(--gray-100); color: var(--gray-700); text-decoration: none; border-radius: 50px; padding: .7rem 1.75rem; font-weight: 700; }
    .rd-cancel:hover { background: var(--gray-200); color: var(--gray-900); }
</style>

<div class="rd-page">
    <div class="rd-card">
        <div class="rd-icon"><i class="fas fa-trash-alt"></i></div>
        <h1 class="rd-title">Delete this review?</h1>
        <p class="rd-sub">This will permanently remove the review of <strong>@Model.Farmer?.FarmName</strong>.</p>

        <div class="rd-review">
            <div class="rd-stars">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="fas fa-star @(i <= Model.RatingValue ? "" : "muted")"></i>
                }
            </div>
            @if (!string.IsNullOrEmpty(Model.Comment))
            {
                <p class="rd-comment">"@Model.Comment"</p>
            }
            <div class="rd-meta">By @(Model.User?.Email ?? "Customer") on @Model.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</div>
        </div>

        <div class="rd-actions">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="RatingID" />
                <button type="submit" class="rd-delete"><i class="fas fa-trash-alt me-1"></i> Delete</button>
            </form>
            <a class="rd-cancel" asp-controller="Farmers" asp-action="Details" asp-route-id="@Model.FarmerID">Cancel</a>
        </div>
    </div>
</div>
